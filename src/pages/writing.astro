---
import Layout from "../components/Layout.astro";
import PostCard from "../components/PostCard.astro";
import { profile } from "../data/profile";
import { getPublishedPosts } from "../utils/posts";

const posts = await getPublishedPosts();
---

<Layout
  title="Writing"
  description={`Writing and notes from ${profile.name}.`}
  canonicalPath="/writing"
>
  <section class="section page-intro">
    <div class="container narrow">
      <p class="eyebrow">Writing</p>
      <h1>Writing</h1>
      <p class="lede">Published notes and posts, written in Markdown and generated as static pages.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {
        posts.length > 0 ? (
          <div class="stack">
            {posts.map((post) => <PostCard post={post} />)}
          </div>
        ) : (
          <p class="muted">TODO: Add published Markdown posts in src/content/posts/.</p>
        )
      }
    </div>
  </section>
</Layout>
